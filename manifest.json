{
  "name": "Hide Jobs",
  "description": "Hide specific job offers from Linkedin, Computrabajo and elempleo.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.computrabajo.com/*",
        "*://*.elempleo.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "css/styles.css",
        "lib/daisyui/daisyui.min.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}