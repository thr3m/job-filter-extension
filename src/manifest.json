{
  "manifest_version": 3,
  "name": "Hide Jobs",
  "version": "1.1.0",
  "description": "Hide specific job offers from Linkedin, Computrabajo, elempleo and indeed",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.computrabajo.com/*",
        "*://*.elempleo.com/*",
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
  }
}
